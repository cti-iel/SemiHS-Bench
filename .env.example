# Copy this file to .env and fill in the keys you need.
# The harness loads .env automatically on startup.
# You only need keys for the providers you plan to evaluate.

# Required for OpenAI / GPT models
OPENAI_API_KEY=your_openai_api_key_here

# Required for Anthropic / Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for Google / Gemini models (also accepted as GOOGLE_API_KEY)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional — only needed for LangSmith experiment tracking
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Required for open-source models via OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional — only needed when evaluating a local HSCode API service
# HSCODE_API_BASE_URL=http://127.0.0.1:18005
