{
  "name": "pilot-openai-open",
  "schema_version": "2.0.0",
  "data": {
    "split": "eval",
    "mode": "open",
    "tiers": [
      1,
      2
    ],
    "limit": 25
  },
  "run": {
    "out_dir": "runs/pilot-openai-open",
    "resume": true,
    "max_parallel_requests": 8,
    "max_parallel_combos": 1,
    "parallel_models": true,
    "max_retries": 2,
    "retry_sleep_s": 3,
    "temperature": 0.0,
    "max_output_tokens": 10000,
    "request_timeout_s": 180,
    "progress_every": 10,
    "web_max_uses": 5,
    "search_context_size": "medium"
  },
  "prompts": {
    "dir": "bench/prompts",
    "version": "default"
  },
  "models": [
    {
      "name": "gpt-5.4-mini",
      "provider": "openai",
      "model": "gpt-5.4-mini",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    },
    {
      "name": "gpt-5.5",
      "provider": "openai",
      "model": "gpt-5.5",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    }
  ],
  "langsmith": {
    "mode": "both",
    "project": "semihs-bench-pilots",
    "upload_reference_datasets": true,
    "include_raw_provider_response": false,
    "dataset_name_template": "semihs-bench-v{benchmark_version}-pilot-{mode}-tier{tier}"
  }
}