{
  "name": "openrouter-open",
  "schema_version": "2.0.0",
  "data": {
    "split": "eval",
    "mode": "open",
    "tiers": [
      1,
      2
    ]
  },
  "run": {
    "out_dir": "runs/openrouter-open",
    "resume": true,
    "max_parallel_requests": 8,
    "max_parallel_combos": 1,
    "parallel_models": true,
    "checkpoint_every": 25,
    "max_retries": 5,
    "retry_sleep_s": 5,
    "temperature": 0.0,
    "max_output_tokens": 10000,
    "request_timeout_s": 300,
    "progress_every": 50,
    "web_max_uses": 5,
    "search_context_size": "medium"
  },
  "prompts": {
    "dir": "bench/prompts",
    "version": "default"
  },
  "models": [
    {
      "name": "qwen3.7-max",
      "provider": "openrouter",
      "model": "qwen/qwen3.7-max",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    },
    {
      "name": "minimax-m3",
      "provider": "openrouter",
      "model": "minimax/minimax-m3",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    },
    {
      "name": "nemotron-ultra",
      "provider": "openrouter",
      "model": "nvidia/nemotron-3-ultra-550b-a55b",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    },
    {
      "name": "glm-5.1",
      "provider": "openrouter",
      "model": "z-ai/glm-5.1",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    },
    {
      "name": "kimi-k2.6",
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.6",
      "reasoning_levels": [
        "none"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ]
    }
  ],
  "langsmith": {
    "mode": "both",
    "project": "semihs-bench",
    "upload_reference_datasets": true,
    "include_raw_provider_response": true
  }
}
