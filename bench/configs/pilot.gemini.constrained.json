{
  "name": "pilot-gemini-constrained",
  "schema_version": "2.0.0",
  "data": {
    "split": "eval",
    "mode": "constrained",
    "tiers": [
      1,
      2
    ],
    "limit": 25
  },
  "run": {
    "out_dir": "runs/pilot-gemini-constrained",
    "resume": true,
    "max_parallel_requests": 20,
    "max_parallel_combos": 1,
    "parallel_models": true,
    "checkpoint_every": 10,
    "max_retries": 3,
    "retry_sleep_s": 5,
    "temperature": 0.0,
    "max_output_tokens": 10000,
    "request_timeout_s": 240,
    "progress_every": 10,
    "web_max_uses": 5,
    "search_context_size": "medium"
  },
  "prompts": {
    "dir": "bench/prompts",
    "version": "default"
  },
  "models": [
    {
      "name": "gemini-3-flash-preview",
      "provider": "gemini",
      "model": "gemini-3-flash-preview",
      "reasoning_levels": [
        "minimal"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ],
      "api_key_env": "GOOGLE_API_KEY"
    },
    {
      "name": "gemini-3.1-pro-preview",
      "provider": "gemini",
      "model": "gemini-3.1-pro-preview",
      "reasoning_levels": [
        "low"
      ],
      "web_modes": [
        "off",
        "unrestricted"
      ],
      "api_key_env": "GOOGLE_API_KEY"
    }
  ],
  "langsmith": {
    "mode": "both",
    "project": "semihs-bench-pilots",
    "upload_reference_datasets": true,
    "include_raw_provider_response": false,
    "dataset_name_template": "semihs-bench-v{benchmark_version}-pilot-{mode}-tier{tier}"
  }
}