{
  "name": "frontier",
  "schema_version": "2.0.0",
  "data": {
    "split": "eval",
    "mode": "constrained",
    "tier": 1,
    "limit": 25
  },
  "run": {
    "out_dir": "runs/frontier",
    "resume": true,
    "max_parallel_requests": 3,
    "max_retries": 2,
    "retry_sleep_s": 2,
    "temperature": 0.0,
    "max_output_tokens": 10000,
    "request_timeout_s": 180,
    "progress_every": 10,
    "web_max_uses": 5,
    "search_context_size": "medium"
  },
  "prompts": {
    "dir": "bench/prompts",
    "version": "default"
  },
  "models": [
    {
      "name": "gpt-4o",
      "provider": "openai",
      "model": "gpt-4o",
      "reasoning_levels": [null],
      "web_modes": ["off"]
    },
    {
      "name": "claude-sonnet-4-6",
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "reasoning_levels": ["medium"],
      "web_modes": ["off"]
    },
    {
      "name": "gemini-2.5-pro",
      "provider": "gemini",
      "model": "gemini-2.5-pro",
      "reasoning_levels": [null],
      "web_modes": ["off"]
    }
  ],
  "langsmith": {
    "mode": "off"
  }
}
